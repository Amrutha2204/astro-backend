{
  "name": "astro-monorepo-tmp-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["astro-monorepo-tmp"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/astro-monorepo-tmp-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": ["astro-monorepo-tmp:build", "astro-monorepo-tmp:serve"]
    }
  }
}
